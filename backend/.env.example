# Required database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=connect_t_user
DB_PASSWORD=replace_with_database_password
DB_NAME=connect_t

# Required in production. Generate a long random value and keep it stable.
JWT_SECRET=replace_with_at_least_48_random_characters

# Protects administrative maintenance endpoints.
ADMIN_API_KEY=replace_with_a_different_long_random_value

# Public backend origin, without a trailing /api path.
PUBLIC_BASE_URL=https://your-api.example.com

# Comma-separated web origins. Native apps do not send an Origin header.
ALLOWED_ORIGINS=https://your-admin.example.com

PORT=3000
# Optional. If omitted, uploads are stored in backend/uploads.
# UPLOAD_DIR=/absolute/path/to/persistent/uploads
MAIN_SUPER_ADMIN_MOBILE=9999999999

# OTP/SMS settings can also be configured from the protected admin settings API.
CONNECT_T_REAL_OTP=1
DOVE_SMS_USER=replace_with_provider_user
DOVE_SMS_KEY=replace_with_provider_key
DOVE_SMS_SENDER=replace_with_sender_id
DOVE_SMS_ACCUSAGE=6
DOVE_SMS_ENTITYID=replace_with_entity_id
DOVE_SMS_TEMPID=replace_with_template_id
DOVE_SMS_URL=https://mobicomm.dove-sms.com/submitsms.jsp
