# Backend runtime
PORT=5000
PUBLIC_BASE_URL=https://api.example.com
UPLOAD_DIR=/absolute/path/to/persistent/uploads

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=connect_t
DB_PASSWORD=replace-with-a-database-password
DB_NAME=connect_t

# Authentication (use independent, randomly generated values)
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_API_KEY=replace-with-a-separate-random-admin-key
MAIN_SUPER_ADMIN_MOBILE=9999999999

# Optional comma-separated browser origins. Native mobile requests do not send
# an Origin header and remain supported.
ALLOWED_ORIGINS=https://connect-t.example.com

# Dove SMS OTP gateway
CONNECT_T_REAL_OTP=1
DOVE_SMS_USER=replace-with-sms-user
DOVE_SMS_KEY=replace-with-sms-key
DOVE_SMS_SENDER=replace-with-approved-sender
DOVE_SMS_ACCUSAGE=6
DOVE_SMS_ENTITYID=replace-with-entity-id
DOVE_SMS_TEMPID=replace-with-template-id
DOVE_SMS_URL=https://sms-provider.example.com/submitsms.jsp
